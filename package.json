{
  "name": "sparkle",
  "version": "2.21.0",
  "description": "Sparkle",
  "main": "./out/main/index.js",
  "author": "Parcoil",
  "homepage": "https://getsparkle.net",
  "scripts": {
    "format": "prettier --write .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev -w",
    "build": "node build.js",
    "build:registry": "pnpm run build -- --registry",
    "build:electron": "pnpm run build:vite && electron-builder",
    "build:vite": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "test": "vitest run  --reporter=verbose",
    "test:watch": "vitest",
    "test:smoke": "node scripts/smoke-test.mjs",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@lucide/lab": "^0.1.2",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-store": "8.1.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.20.0",
    "posthog-js": "^1.362.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.8.2",
    "react-toastify": "^11.1.0",
    "remark-gfm": "^4.0.1",
    "systeminformation": "^5.31.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^25.0.8",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.7"
  },
  "repository": "https://github.com/Parcoil/Sparkle",
  "build": {
    "electronLanguages": [
      "en-US"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Parcoil",
        "repo": "Sparkle",
        "releaseType": "release"
      }
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "*.exe",
          "*.nip",
          "*.pow"
        ]
      }
    ],
    "appId": "com.parcoil.sparkle",
    "productName": "sparkle",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "!**/.vscode/*",
      "!src/*",
      "!dist-old",
      "!dist-2",
      "!electron-builde.yml",
      "!images/*",
      "!electron.vite.config.{js,ts,mjs,cjs}",
      "!{.eslintignore,.eslintrc.cjs,.prettierignore,.prettierrc.yaml,dev-app-update.yml,CHANGELOG.md,README.md}",
      "!{.env,.env.*,.npmrc,pnpm-lock.yaml,yarn.lock}",
      "!docs/**",
      "!eslint.config.mjs",
      "!get.ps1",
      "!license",
      "!trusted-dependencies-scripts.json",
      "!postcss.config.js",
      "!tsconfig.json",
      "!tsconfig.node.json",
      "!tsconfig.web.json",
      "!build.js",
      "!jsconfig.json",
      "!LICENSE",
      "!bucket/**",
      "!pnpm-workspace.yaml",
      "!vitest.config.ts",
      "!resources/**",
      "!chocolatey/**",
      "!node_modules/@headlessui/**",
      "!node_modules/@lucide/**",
      "!node_modules/lucide-react/**",
      "!node_modules/react/**",
      "!node_modules/preact/**",
      "!node_modules/react-dom/**",
      "!node_modules/react-router-dom/**",
      "!node_modules/react-router/**",
      "!node_modules/react-toastify/**",
      "!node_modules/tailwindcss/**",
      "!node_modules/postcss/**",
      "!node_modules/zustand/**",
      "!node_modules/posthog-js/**",
      "!node_modules/@posthog/**",
      "!node_modules/@opentelemetry/**",
      "!node_modules/postgres/**",
      "!node_modules/clsx/**",
      "!node_modules/debounce/**",
      "!node_modules/js-tokens/**",
      "!node_modules/loose-envify/**",
      "!node_modules/object-assign/**",
      "!node_modules/prop-types/**",
      "!node_modules/react-is/**",
      "!node_modules/scheduler/**",
      "!node_modules/uuid/**"
    ],
    "win": {
      "executableName": "sparkle",
      "requestedExecutionLevel": "requireAdministrator",
      "icon": "resources/sparkle2.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "artifactName": "${name}-${version}-setup.${ext}",
      "shortcutName": "${productName}",
      "uninstallDisplayName": "${productName}",
      "createDesktopShortcut": "always"
    },
    "npmRebuild": false
  },
  "packageManager": "pnpm@10.29.3"
}
